 35:   function getPreviewMeta(card) {
 36:     const s = (card.sections || []).find((s) => s.type === 'key-value' && s.keyValues);
 37:     if (!s) return '';
 38:     return Object.entries(s.keyValues).slice(0, 3).map(([k, v]) => `${k}: ${v}`).join(' · ');
 39:   }
