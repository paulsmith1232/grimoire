 46: export default function CropOverlay({ imgDataUrl, onConfirm, onCancel }) {
 47:   const canvasRef = useRef(null);
 48:   const imgRef = useRef(new Image());
 49:   const stateRef = useRef({ dW: 0, dH: 0, drawing: false, startX: 0, startY: 0 });
 50:   const currentRectRef = useRef(null); // in-progress draft while dragging
 51:   const regionsRef = useRef([]);       // mirror of regions state for use in event handlers
 52: 
 53:   const [regions, setRegions] = useState([]);
 54:   const [fullPage, setFullPage] = useState(true);
 55: 
 56:   useEffect(() => { regionsRef.current = regions; }, [regions]);
 57: 
 58:   const draw = useCallback((draftRect = null) => {
 59:     const canvas = canvasRef.current;
 60:     if (!canvas) return;
 61:     const ctx = canvas.getContext('2d');
 62:     const { dW, dH } = stateRef.current;
 63:     ctx.clearRect(0, 0, dW, dH);
 64:     ctx.drawImage(imgRef.current, 0, 0, dW, dH);
 65: 
 66:     const all = draftRect ? [...regionsRef.current, draftRect] : regionsRef.current;
 67:     for (const r of all) {
 68:       ctx.fillStyle = GOLD_FILL;
 69:       ctx.fillRect(r.x, r.y, r.width, r.height);
 70:       drawCornerBrackets(ctx, r.x, r.y, r.width, r.height);
 71:       if (r !== draftRect) drawXBtn(ctx, r);
 72:     }
 73:   }, []);
 74: 
 75:   useEffect(() => {
 76:     const img = imgRef.current;
 77:     img.onload = () => {
 78:       const maxW = window.innerWidth;
 79:       const maxH = window.innerHeight - 110;
 80:       const scale = Math.min(maxW / img.naturalWidth, maxH / img.naturalHeight, 1);
 81:       const dW = Math.round(img.naturalWidth * scale);
 82:       const dH = Math.round(img.naturalHeight * scale);
 83:       stateRef.current.dW = dW;
 84:       stateRef.current.dH = dH;
 85:       const canvas = canvasRef.current;
 86:       if (canvas) {
 87:         canvas.width = dW;
 88:         canvas.height = dH;
 89:         canvas.style.width = dW + 'px';
 90:         canvas.style.height = dH + 'px';
 91:       }
 92:       draw();
 93:     };
 94:     img.src = imgDataUrl;
 95:   }, [imgDataUrl, draw]);
 96: 
 97:   useEffect(() => {
 98:     draw(currentRectRef.current);
 99:   }, [regions, draw]);
100: 
101:   function getPosOnCanvas(e) {
102:     const r = canvasRef.current.getBoundingClientRect();
103:     return {
104:       x: Math.max(0, Math.min(e.clientX - r.left, stateRef.current.dW)),
105:       y: Math.max(0, Math.min(e.clientY - r.top, stateRef.current.dH)),
106:     };
107:   }
108: 
109:   function hitTestXBtn(p) {
110:     for (const r of regionsRef.current) {
111:       const { cx, cy } = getXBtnCenter(r);
112:       const dx = p.x - cx, dy = p.y - cy;
113:       if (dx * dx + dy * dy <= (X_R + 4) * (X_R + 4)) return r.id;
114:     }
115:     return null;
116:   }
117: 
118:   function handlePointerDown(e) {
119:     const canvas = canvasRef.current;
120:     const r = canvas.getBoundingClientRect();
121:     if (e.clientX < r.left || e.clientX > r.right || e.clientY < r.top || e.clientY > r.bottom) return;
122: 
123:     const p = getPosOnCanvas(e);
124:     const hitId = hitTestXBtn(p);
125:     if (hitId) {
126:       setRegions((prev) => prev.filter((r) => r.id !== hitId));
127:       return;
128:     }
129: 
130:     e.currentTarget.setPointerCapture(e.pointerId);
131:     stateRef.current.startX = p.x;
132:     stateRef.current.startY = p.y;
133:     stateRef.current.drawing = true;
134:     currentRectRef.current = null;
135:   }
136: 
137:   function handlePointerMove(e) {
138:     if (!stateRef.current.drawing) return;
139:     const p = getPosOnCanvas(e);
140:     const { startX, startY } = stateRef.current;
141:     const x = Math.min(startX, p.x);
142:     const y = Math.min(startY, p.y);
143:     const width = Math.abs(p.x - startX);
144:     const height = Math.abs(p.y - startY);
145:     if (width > 5 && height > 5) {
146:       currentRectRef.current = { id: '__draft', x, y, width, height };
147:       draw(currentRectRef.current);
148:     }
149:   }
150: 
151:   function handlePointerUp() {
152:     if (!stateRef.current.drawing) return;
153:     stateRef.current.drawing = false;
154:     const draft = currentRectRef.current;
155:     currentRectRef.current = null;
156:     if (draft && draft.width >= MIN_RECT && draft.height >= MIN_RECT) {
157:       const id = Date.now().toString(36) + Math.random().toString(36).slice(2, 5);
158:       setRegions((prev) => [...prev, { id, x: draft.x, y: draft.y, width: draft.width, height: draft.height }]);
159:     } else {
160:       draw();
161:     }
162:   }
163: 
164:   function handleConfirm() {
165:     if (regions.length === 0) return;
166:     const img = imgRef.current;
167:     const { dW, dH } = stateRef.current;
168:     const scaleX = img.naturalWidth / dW;
169:     const scaleY = img.naturalHeight / dH;
170: 
171:     let images;
172:     if (fullPage) {
173:       // Bake overlays onto full-size offscreen canvas
174:       const off = document.createElement('canvas');
175:       off.width = img.naturalWidth;
176:       off.height = img.naturalHeight;
177:       const ctx = off.getContext('2d');
178:       ctx.drawImage(img, 0, 0);
179:       for (const r of regions) {
180:         const rx = r.x * scaleX, ry = r.y * scaleY;
181:         const rw = r.width * scaleX, rh = r.height * scaleY;
182:         ctx.fillStyle = GOLD_FILL;
183:         ctx.fillRect(rx, ry, rw, rh);
184:         drawCornerBrackets(ctx, rx, ry, rw, rh);
185:       }
186:       images = [{ base64: off.toDataURL('image/jpeg', 0.92).split(',')[1], mediaType: 'image/jpeg' }];
187:     } else {
188:       images = regions.map((r) => {
189:         const off = document.createElement('canvas');
190:         off.width = Math.round(r.width * scaleX);
191:         off.height = Math.round(r.height * scaleY);
192:         off.getContext('2d').drawImage(
193:           img,
194:           Math.round(r.x * scaleX), Math.round(r.y * scaleY), off.width, off.height,
195:           0, 0, off.width, off.height,
196:         );
197:         return { base64: off.toDataURL('image/jpeg', 0.92).split(',')[1], mediaType: 'image/jpeg' };
198:       });
199:     }
200: 
201:     onConfirm(images, fullPage);
202:   }
203: 
204:   const scanLabel = regions.length === 0 ? 'Scan Regions'
205:     : regions.length === 1 ? 'Scan 1 Region'
206:     : `Scan ${regions.length} Regions`;
207: 
208:   return createPortal(
209:     <div
210:       className="crop-overlay"
211:       style={{ touchAction: 'none' }}
212:       onPointerDown={handlePointerDown}
213:       onPointerMove={handlePointerMove}
214:       onPointerUp={handlePointerUp}
215:     >
216:       <div className="crop-toolbar">
217:         <button className="btn btn-secondary btn-sm" onClick={onCancel}>Cancel</button>
218:         <span style={{ color: 'var(--text)', fontSize: 14, fontWeight: 600 }}>Select Area</span>
219:         <button
220:           className={'btn btn-sm ' + (fullPage ? 'btn-primary' : 'btn-secondary')}
221:           onClick={() => setFullPage((v) => !v)}
222:           style={{ minWidth: 84 }}
223:         >
224:           {fullPage ? 'Full Page' : 'Crop Only'}
225:         </button>
226:       </div>
227:       <div className="crop-canvas-wrap">
228:         <canvas ref={canvasRef} style={{ display: 'block' }} />
229:         {regions.length === 0 && (
230:           <div className="crop-hint">Draw rectangles to highlight regions</div>
231:         )}
232:       </div>
233:       <div style={{ padding: '12px 16px', background: 'var(--surface)', flexShrink: 0 }}>
234:         <button
235:           className="btn btn-primary btn-block"
236:           disabled={regions.length === 0}
237:           onClick={handleConfirm}
238:         >
239:           {scanLabel}
240:         </button>
241:       </div>
242:     </div>,
243:     document.body
244:   );
245: }
