 5: /**
 6:  * Renders text with [[cardId|display text]] links as tappable gold spans.
 7:  * Clicking a link navigates to that card.
 8:  */
 9: export default function LinkedText({ text, className, style }) {
10:   const { state, navigateToCard } = useApp();
11: 
12:   if (!text) return null;
13: 
14:   const segments = segmentText(text);
15: 
16:   if (segments.length === 0) return null;
17:   if (segments.length === 1 && segments[0].type === 'text') {
18:     return <span className={className} style={style}>{segments[0].content}</span>;
19:   }
20: 
21:   return (
22:     <span className={className} style={style}>
23:       {segments.map((seg, i) => {
24:         if (seg.type === 'text') {
25:           return <span key={i}>{seg.content}</span>;
26:         }
27: 
28:         const targetCard = state.cards.find((c) => c.id === seg.cardId);
29:         const exists = !!targetCard;
30: 
31:         return (
32:           <span
33:             key={i}
34:             className="linked-term"
35:             data-exists={exists}
36:             title={exists ? `Go to: ${targetCard.name}` : `Card not found: ${seg.cardId}`}
37:             onClick={(e) => {
38:               e.stopPropagation();
39:               if (exists) navigateToCard(seg.cardId, false);
40:             }}
41:           >
42:             {seg.displayText}
43:           </span>
44:         );
45:       })}
46:     </span>
47:   );
48: }
</file>

