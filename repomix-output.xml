 41: // ── Migration from old localStorage format ──
 42: export async function migrateFromLocalStorage() {
 43:   const raw = localStorage.getItem('grimoire-data');
 44:   if (!raw) return false;
 45: 
 46:   try {
 47:     const data = JSON.parse(raw);
 48:     const cards = data.cards || [];
 49:     const tags = data.tags || data.characters || [];
 50:     const profiles = data.profiles || [];
 51:     const apiKey = localStorage.getItem('grimoire-api-key') || '';
 52: 
 53:     // Migrate old card formats
 54:     cards.forEach((card) => {
 55:       if (card.characters && !card.tags) {
 56:         card.tags = card.characters;
 57:         delete card.characters;
 58:       }
 59:       if (!card.sections) migrateCardToSections(card);
 60:     });
 61: 
 62:     // Ensure D&D profile exists and migrate profile model
 63:     if (!profiles.find((p) => p.id === 'dnd-5e')) {
 64:       profiles.unshift({ ...DND_PROFILE });
 65:     }
 66:     const migratedProfiles = profiles.map(migrateProfileFields);
 67: 
 68:     // Write to IndexedDB
 69:     await db.transaction('rw', db.cards, db.profiles, db.tags, db.settings, async () => {
 70:       await db.cards.bulkPut(cards);
 71:       await db.profiles.bulkPut(migratedProfiles);
 72:       await db.tags.bulkPut(tags.map((t) => (typeof t === 'string' ? { name: t } : t)));
 73:       if (apiKey) await db.settings.put({ key: 'apiKey', value: apiKey });
 74:     });
 75: 
 76:     // Mark migration complete — keep old data as safety net
 77:     localStorage.setItem('grimoire-migrated-to-idb', 'true');
 78:     return true;
 79:   } catch (e) {
 80:     console.error('Migration failed:', e);
 81:     return false;
 82:   }
 83: }
 84: 
 85: function migrateCardToSections(card) {
 86:   const oldDnd = ['spell', 'cantrip', 'class_feature', 'racial_trait', 'item_ability'];
 87: 
 88:   if (oldDnd.includes(card.type)) {
 89:     card.profileId = 'dnd-5e';
 90:     card.sections = [];
 91:     const kv = {};
 92:     if (card.level != null) kv['Level'] = card.level === 0 ? 'Cantrip' : String(card.level);
 93:     if (card.school) kv['School'] = card.school;
 94:     if (card.castingTime) kv['Casting Time'] = card.castingTime;
 95:     if (card.range) kv['Range'] = card.range;
 96:     if (card.components) kv['Components'] = card.components;
 97:     if (card.duration) kv['Duration'] = card.duration;
 98:     if (card.concentration != null) kv['Concentration'] = card.concentration ? 'Yes' : 'No';
 99:     if (card.classes) kv['Classes'] = card.classes;
100:     const labels = { spell: 'Spell', cantrip: 'Cantrip', class_feature: 'Class Feature', racial_trait: 'Racial Trait', item_ability: 'Item' };
101:     kv['Type'] = labels[card.type] || card.type;
102:     if (Object.keys(kv).length) card.sections.push({ name: 'Stats', type: 'key-value', keyValues: kv, priority: 1 });
103:     if (card.description) card.sections.push({ name: 'Description', type: 'text', content: card.description, priority: 2 });
104:     if (card.higherLevels) card.sections.push({ name: 'At Higher Levels', type: 'text', content: card.higherLevels, priority: 3 });
105:   } else {
106:     card.profileId = card.profileId || '';
107:     card.sections = [];
108:     if (card.keyValues && Object.keys(card.keyValues).length) {
109:       card.sections.push({ name: 'Stats', type: 'key-value', keyValues: card.keyValues, priority: 1 });
110:     }
111:     if (card.description) {
112:       card.sections.push({ name: 'Description', type: 'text', content: card.description, priority: card.sections.length + 1 });
113:     }
114:   }
115: 
116:   // Clean up old fields
117:   for (const k of ['type', 'level', 'school', 'castingTime', 'range', 'components', 'duration', 'concentration', 'classes', 'higherLevels', 'keyValues', 'description', 'category']) {
118:     delete card[k];
119:   }
120: }
121: 
122: // ── Profile migration: sections/scanInstructions → fields/additionalInstructions ──
123: export function migrateProfileFields(profile) {
124:   if (profile.fields) return profile; // already on new model
125:   const { sections, scanInstructions, ...rest } = profile;
126:   const fields = (sections || []).map((s) => ({
127:     key: (s.name || '').toLowerCase().replace(/\s+/g, '_').replace(/[^a-z0-9_]/g, ''),
128:     label: s.name || '',
129:   }));
130:   return {
131:     ...rest,
132:     fields,
133:     additionalInstructions: scanInstructions || '',
134:     useCustomPrompt: rest.useCustomPrompt || false,
135:     customPrompt: rest.customPrompt || '',
136:   };
137: }
