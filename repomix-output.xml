  1: const SUMMARY_INSTRUCTION = `Also generate a "summary" field: a single sentence under 15 words capturing what this card is and its key relationships or category. This is used for indexing, not display.`;
  2: 
  3: // ── Dynamic prompt builder ──
  4: export function buildPrompt(profile) {
  5:   if (profile.useCustomPrompt) {
  6:     return (profile.customPrompt || '') + `\n\n${SUMMARY_INSTRUCTION}`;
  7:   }
  8: 
  9:   const fieldLabels = (profile.fields || []).map((f) => `"${f.label}"`).join(', ');
 10:   const fieldSection = fieldLabels
 11:     ? `This profile expects these fields (in order): ${fieldLabels}`
 12:     : '';
 13: 
 14:   // Support both new (additionalInstructions) and legacy (scanInstructions) field names
 15:   const additionalInstructions = profile.additionalInstructions || profile.scanInstructions || '';
 16: 
 17:   return `You are a reference card parser. Extract content from the image and return ONLY valid JSON with no markdown, no backticks, no preamble.
 18: 
 19: Schema:
 20: {
 21:   "name": "string",
 22:   "summary": "string",
 23:   "source": "string|null",
 24:   "sections": [
 25:     {
 26:       "name": "string",
 27:       "type": "text|key-value",
 28:       "content": "string|null",
 29:       "keyValues": {"key":"value"}|null,
 30:       "priority": number
 31:     }
 32:   ]
 33: }
 34: 
 35: ${fieldSection}
 36: 
 37: ${additionalInstructions}
 38: 
 39: Rules:
 40: - Return sections matching the expected fields, in the order listed. Only include sections that have actual content.
 41: - For structured data (stats, properties, numbers): use type "key-value" with keyValues as string pairs.
 42: - For prose text (descriptions, abilities, lore): use type "text" with content string.
 43: - Preserve body text faithfully.
 44: - If multiple entries visible, extract only the most prominent one.
 45: - ${SUMMARY_INSTRUCTION}
 46: - Return ONLY the JSON object.`;
 47: }
 48: 
 49: // ── Parse card from one or more images ──
 50: // images: [{ base64, mediaType }, ...]
 51: // opts.fullPageWithRegions: true when Full Page mode — image has gold overlay highlights
 52: export async function parseCardImage(images, apiKey, profile, opts = {}) {
 53:   if (!apiKey) throw new Error('No API key configured');
 54:   if (!profile) throw new Error('No scan profile selected');
 55: 
 56:   const imageBlocks = images.map(({ base64, mediaType }) => ({
 57:     type: 'image',
 58:     source: { type: 'base64', media_type: mediaType, data: base64 },
 59:   }));
 60: 
 61:   let prompt;
 62:   if (opts.fullPageWithRegions) {
 63:     prompt = 'This image shows a full page with highlighted regions (gold corner-bracket overlays). Focus your extraction on the highlighted areas when building the card.';
 64:   } else if (images.length > 1) {
 65:     prompt = 'These images are cropped regions from a page. Extract the content from all regions into a single structured card.';
 66:   } else {
 67:     prompt = 'Extract the content from this image into a structured card.';
 68:   }
 69: 
 70:   let systemPrompt = buildPrompt(profile);
 71:   if (opts.scanInstructions) {
 72:     systemPrompt += `\n\nAdditional instructions for this scan: ${opts.scanInstructions.trim()}`;
 73:   }
 74: 
 75:   const res = await fetch('https://api.anthropic.com/v1/messages', {
 76:     method: 'POST',
 77:     headers: {
 78:       'Content-Type': 'application/json',
 79:       'x-api-key': apiKey,
 80:       'anthropic-version': '2023-06-01',
 81:       'anthropic-dangerous-direct-browser-access': 'true',
 82:     },
 83:     body: JSON.stringify({
 84:       model: 'claude-sonnet-4-20250514',
 85:       max_tokens: 2000,
 86:       system: systemPrompt,
 87:       messages: [
 88:         {
 89:           role: 'user',
 90:           content: [...imageBlocks, { type: 'text', text: prompt }],
 91:         },
 92:       ],
 93:     }),
 94:   });
 95: 
 96:   if (!res.ok) {
 97:     const e = await res.json().catch(() => ({}));
 98:     throw new Error(e?.error?.message || 'API error: ' + res.status);
 99:   }
100: 
101:   const data = await res.json();
102:   const text = (data.content || []).map((b) => b.text || '').join('');
103:   return JSON.parse(text.replace(/```json|```/g, '').trim());
104: }
105: 
106: // ── Chat message send ──
107: // messages: Anthropic-format array (role/content). tools: optional array of tool defs.
108: export async function sendChatMessage(messages, systemPrompt, apiKey, tools = []) {
109:   if (!apiKey) throw new Error('No API key configured');
110: 
111:   const body = {
112:     model: 'claude-sonnet-4-20250514',
113:     max_tokens: 4000,
114:     system: systemPrompt,
115:     messages,
116:   };
117:   if (tools.length > 0) body.tools = tools;
118: 
119:   const res = await fetch('https://api.anthropic.com/v1/messages', {
120:     method: 'POST',
121:     headers: {
122:       'Content-Type': 'application/json',
123:       'x-api-key': apiKey,
124:       'anthropic-version': '2023-06-01',
125:       'anthropic-dangerous-direct-browser-access': 'true',
126:     },
127:     body: JSON.stringify(body),
128:   });
129: 
130:   if (!res.ok) {
131:     const e = await res.json().catch(() => ({}));
132:     throw new Error(e?.error?.message || 'API error: ' + res.status);
133:   }
134: 
135:   const data = await res.json();
136:   const text = (data.content || [])
137:     .filter((b) => b.type === 'text')
138:     .map((b) => b.text)
139:     .join('');
140: 
141:   return { text: text || '(No text response)', usage: data.usage };
142: }
143: 
144: // ── Crop image helper ──
145: export function cropImage(imgEl, rect, dispW, dispH) {
146:   const c = document.createElement('canvas');
147:   const sx = (rect.x * imgEl.naturalWidth) / dispW;
148:   const sy = (rect.y * imgEl.naturalHeight) / dispH;
149:   const sw = (rect.w * imgEl.naturalWidth) / dispW;
150:   const sh = (rect.h * imgEl.naturalHeight) / dispH;
151:   c.width = Math.round(sw);
152:   c.height = Math.round(sh);
153:   c.getContext('2d').drawImage(
154:     imgEl, Math.round(sx), Math.round(sy), Math.round(sw), Math.round(sh),
155:     0, 0, c.width, c.height
156:   );
157:   return c.toDataURL('image/jpeg', 0.92).split(',')[1];
158: }
