  1: import React, { useState, useEffect, useRef } from 'react';
  2: import { createPortal } from 'react-dom';
  3: import { sendChatMessage } from '../api';
  4: import { useApp } from '../context';
  5: 
  6: const WEB_SEARCH_TOOL = { type: 'web_search_20250305', name: 'web_search' };
  7: 
  8: // Placeholder system prompts — full versions come with sections 5 & 6
  9: const SYSTEM_PROMPTS = {
 10:   create: 'You are a helpful assistant for the Grimoire app, which helps users organize reference cards. Help the user create a new scan profile by understanding their use case and the fields they need. When you are ready to propose a schema, output it in a ```json code fence with { "type": "schema_proposal", "name": "...", "fields": [...] }.',
 11:   update: 'You are a helpful assistant for the Grimoire app. Help the user update their existing scan profile. When you are ready to propose changes, output them in a ```json code fence with { "type": "schema_diff", "changes": [...] }.',
 12: };
 13: 
 14: function buildApiMessages(messages) {
 15:   return messages
 16:     .filter((m) => m.role === 'user' || m.role === 'assistant')
 17:     .map((msg) => {
 18:       if (msg.role === 'user') {
 19:         if (msg.images?.length > 0) {
 20:           return {
 21:             role: 'user',
 22:             content: [
 23:               ...msg.images.map((img) => ({
 24:                 type: 'image',
 25:                 source: { type: 'base64', media_type: img.mediaType, data: img.base64 },
 26:               })),
 27:               { type: 'text', text: msg.content || '' },
 28:             ],
 29:           };
 30:         }
 31:         return { role: 'user', content: msg.content || '' };
 32:       }
 33:       // assistant — use rawText so JSON fences are preserved in history
 34:       return { role: 'assistant', content: msg.rawText || (typeof msg.content === 'string' ? msg.content : '') };
 35:     });
 36: }
 37: 
 38: function parseAssistantResponse(text) {
 39:   const fenceMatch = text.match(/```json\s*([\s\S]*?)```/);
 40:   if (!fenceMatch) return { content: text, rawText: text, parsed: null };
 41:   try {
 42:     const parsed = JSON.parse(fenceMatch[1].trim());
 43:     return { content: parsed, rawText: text, parsed };
 44:   } catch {
 45:     return { content: text, rawText: text, parsed: null };
 46:   }
 47: }
 48: 
 49: export default function ChatPanel({ mode, existingProfile, onClose, onSaveProfile }) {
 50:   const { state } = useApp();
 51:   const [messages, setMessages] = useState([]);
 52:   const [inputText, setInputText] = useState('');
 53:   const [attachedImages, setAttachedImages] = useState([]);
 54:   const [isLoading, setIsLoading] = useState(false);
 55:   const [visible, setVisible] = useState(false);
 56:   const threadRef = useRef(null);
 57:   const inputRef = useRef(null);
 58:   const fileRef = useRef(null);
 59: 
 60:   const title = mode === 'create'
 61:     ? 'Create Profile'
 62:     : `Update Profile: ${existingProfile?.name || ''}`;
 63: 
 64:   // Slide-in on mount
 65:   useEffect(() => {
 66:     requestAnimationFrame(() => setVisible(true));
 67:   }, []);
 68: 
 69:   // Auto-scroll to bottom on new messages or loading state change
 70:   useEffect(() => {
 71:     if (threadRef.current) {
 72:       threadRef.current.scrollTop = threadRef.current.scrollHeight;
 73:     }
 74:   }, [messages, isLoading]);
 75: 
 76:   async function handleSend() {
 77:     const text = inputText.trim();
 78:     if (!text && attachedImages.length === 0) return;
 79:     if (isLoading) return;
 80: 
 81:     const userMsg = {
 82:       role: 'user',
 83:       content: text,
 84:       images: attachedImages,
 85:       timestamp: new Date(),
 86:     };
 87: 
 88:     const updatedMessages = [...messages, userMsg];
 89:     setMessages(updatedMessages);
 90:     setInputText('');
 91:     setAttachedImages([]);
 92:     if (inputRef.current) inputRef.current.style.height = 'auto';
 93:     setIsLoading(true);
 94: 
 95:     try {
 96:       const apiMessages = buildApiMessages(updatedMessages);
 97:       const systemPrompt = SYSTEM_PROMPTS[mode] || SYSTEM_PROMPTS.create;
 98: 
 99:       // Cost guardrail: warn before large calls
100:       const estimatedTokens = JSON.stringify({ messages: apiMessages, system: systemPrompt }).length / 4;
101:       if (estimatedTokens > 30000) {
102:         const kTokens = Math.round(estimatedTokens / 1000);
103:         const ok = window.confirm(`This will send approximately ${kTokens}k tokens to Claude. Continue?`);
104:         if (!ok) {
105:           setIsLoading(false);
106:           // Restore input state
107:           setMessages((prev) => prev.filter((m) => m !== userMsg));
108:           setInputText(text);
109:           setAttachedImages(userMsg.images);
110:           return;
111:         }
112:       }
113: 
114:       const { text: responseText, usage } = await sendChatMessage(
115:         apiMessages, systemPrompt, state.apiKey, [WEB_SEARCH_TOOL]
116:       );
117: 
118:       const { content, rawText, parsed } = parseAssistantResponse(responseText);
119:       setMessages((prev) => [...prev, {
120:         role: 'assistant',
121:         content,
122:         rawText,
123:         parsed,
124:         usage,
125:         timestamp: new Date(),
126:       }]);
127:     } catch (err) {
128:       setMessages((prev) => [...prev, {
129:         role: 'error',
130:         content: err.message || 'Request failed.',
131:         timestamp: new Date(),
132:       }]);
133:     } finally {
134:       setIsLoading(false);
135:     }
136:   }
137: 
138:   function handleKeyDown(e) {
139:     if (e.key === 'Enter' && !e.shiftKey) {
140:       e.preventDefault();
141:       handleSend();
142:     }
143:   }
144: 
145:   async function handleFileAttach(e) {
146:     const files = Array.from(e.target.files || []);
147:     e.target.value = '';
148:     for (const file of files) {
149:       const dataUrl = await new Promise((resolve) => {
150:         const reader = new FileReader();
151:         reader.onload = (ev) => resolve(ev.target.result);
152:         reader.readAsDataURL(file);
153:       });
154:       setAttachedImages((prev) => [
155:         ...prev,
156:         { base64: dataUrl.split(',')[1], dataUrl, mediaType: file.type || 'image/jpeg' },
157:       ]);
158:     }
159:   }
160: 
161:   function renderMessage(msg, idx) {
162:     if (msg.role === 'error') {
163:       return (
164:         <div key={idx} className="chat-bubble chat-bubble-error">{msg.content}</div>
165:       );
166:     }
167: 
168:     if (msg.role === 'user') {
169:       return (
170:         <div key={idx} style={{ display: 'flex', flexDirection: 'column', alignItems: 'flex-end', gap: 4 }}>
171:           {msg.images?.length > 0 && (
172:             <div style={{ display: 'flex', gap: 4, justifyContent: 'flex-end', flexWrap: 'wrap' }}>
173:               {msg.images.map((img, i) => (
174:                 <img key={i} src={img.dataUrl} alt="" style={{ width: 52, height: 52, objectFit: 'cover', borderRadius: 6, border: '1px solid var(--border)' }} />
175:               ))}
176:             </div>
177:           )}
178:           {msg.content && <div className="chat-bubble chat-bubble-user">{msg.content}</div>}
179:         </div>
180:       );
181:     }
182: 
183:     // assistant
184:     const isStructured = msg.parsed && (msg.parsed.type === 'schema_proposal' || msg.parsed.type === 'schema_diff');
185:     return (
186:       <div key={idx} style={{ display: 'flex', flexDirection: 'column', alignItems: 'flex-start', gap: 2 }}>
187:         <div className="chat-bubble chat-bubble-assistant">
188:           {isStructured
189:             ? <em style={{ color: 'var(--accent)' }}>Schema proposal received — review UI coming in a future update.</em>
190:             : (typeof msg.content === 'string' ? msg.content : JSON.stringify(msg.content, null, 2))
191:           }
192:         </div>
193:         {msg.usage && (
194:           <div className="chat-usage">
195:             ~{msg.usage.input_tokens?.toLocaleString()} input · ~{msg.usage.output_tokens?.toLocaleString()} output tokens
196:           </div>
197:         )}
198:       </div>
199:     );
200:   }
201: 
202:   return createPortal(
203:     <div className="chat-panel-backdrop" onClick={onClose}>
204:       <div
205:         className={'chat-panel' + (visible ? ' chat-panel-visible' : '')}
206:         onClick={(e) => e.stopPropagation()}
207:       >
208:         {/* Header */}
209:         <div className="chat-panel-header">
210:           <span className="chat-panel-title">{title}</span>
211:           <button className="chat-panel-close" onClick={onClose}>✕</button>
212:         </div>
213: 
214:         {/* Message thread */}
215:         <div className="chat-panel-thread" ref={threadRef}>
216:           {messages.length === 0 && (
217:             <div style={{ textAlign: 'center', color: 'var(--text-dim)', fontSize: 13, paddingTop: 40 }}>
218:               {mode === 'create'
219:                 ? 'Describe the cards you want to organize — what game, system, or topic?'
220:                 : 'What would you like to change about this profile?'}
221:             </div>
222:           )}
223:           {messages.map(renderMessage)}
224:           {isLoading && (
225:             <div className="chat-bubble chat-bubble-assistant chat-bubble-loading">…</div>
226:           )}
227:         </div>
228: 
229:         {/* Input area */}
230:         <div className="chat-panel-input-area">
231:           {attachedImages.length > 0 && (
232:             <div className="chat-thumbs">
233:               {attachedImages.map((img, i) => (
234:                 <div key={i} className="chat-thumb">
235:                   <img src={img.dataUrl} alt="" />
236:                   <button
237:                     className="chat-thumb-remove"
238:                     onClick={() => setAttachedImages((prev) => prev.filter((_, j) => j !== i))}
239:                   >✕</button>
240:                 </div>
241:               ))}
242:             </div>
243:           )}
244:           <div className="chat-input-row">
245:             <input
246:               ref={fileRef}
247:               type="file"
248:               accept="image/*"
249:               multiple
250:               style={{ display: 'none' }}
251:               onChange={handleFileAttach}
252:             />
253:             <button
254:               className="btn btn-secondary btn-sm chat-attach-btn"
255:               onClick={() => fileRef.current?.click()}
256:               title="Attach image"
257:             >📎</button>
258:             <textarea
259:               ref={inputRef}
260:               value={inputText}
261:               rows={2}
262:               placeholder="Type or dictate a message..."
263:               style={{ flex: 1, fontSize: 16, resize: 'none', overflowY: 'auto', maxHeight: 168 }}
264:               onChange={(e) => {
265:                 setInputText(e.target.value);
266:                 e.target.style.height = 'auto';
267:                 e.target.style.height = Math.min(e.target.scrollHeight, 168) + 'px';
268:               }}
269:               onKeyDown={handleKeyDown}
270:             />
271:             <button
272:               className="btn btn-primary btn-sm chat-send-btn"
273:               disabled={isLoading || (!inputText.trim() && attachedImages.length === 0)}
274:               onClick={handleSend}
275:             >Send</button>
276:           </div>
277:         </div>
278:       </div>
279:     </div>,
280:     document.body
281:   );
282: }
