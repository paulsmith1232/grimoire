156: export async function getAllProfiles() {
157:   let profiles = await db.profiles.toArray();
158: 
159:   // Migrate any profiles still on the old sections/scanInstructions model
160:   const toSave = [];
161:   profiles = profiles.map((p) => {
162:     if (!p.fields) {
163:       const m = migrateProfileFields(p);
164:       toSave.push(m);
165:       return m;
166:     }
167:     return p;
168:   });
169:   if (toSave.length > 0) {
170:     await db.profiles.bulkPut(toSave);
171:   }
172: 
173:   // Ensure D&D profile
174:   if (!profiles.find((p) => p.id === 'dnd-5e')) {
175:     await db.profiles.put({ ...DND_PROFILE });
176:     profiles.unshift({ ...DND_PROFILE });
177:   }
178:   return profiles;
179: }
