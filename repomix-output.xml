  1: import React, { createContext, useContext, useReducer, useEffect, useCallback, useRef } from 'react';
  2: import {
  3:   getAllCards, putCard, deleteCard as dbDeleteCard,
  4:   getAllProfiles, putProfile, deleteProfile as dbDeleteProfile,
  5:   getAllTags, addTag as dbAddTag, removeTag as dbRemoveTag,
  6:   getSetting, setSetting,
  7:   migrateFromLocalStorage, createBackup, DND_PROFILE, genId,
  8:   getQAState as dbGetQAState, saveQAState as dbSaveQAState, resetQAState as dbResetQAState,
  9: } from './db';
 10: 
 11: const AppContext = createContext(null);
 12: 
 13: const initialState = {
 14:   cards: [],
 15:   profiles: [],
 16:   tags: [],
 17:   apiKey: '',
 18:   loading: true,
 19:   currentTab: 'library',
 20:   selectedCardId: null,
 21:   editingCardId: null,
 22:   editingProfileId: null,
 23:   filterProfile: 'all',
 24:   filterTag: 'all',
 25:   searchQuery: '',
 26:   scanProfileId: '',
 27: };
 28: 
 29: function reducer(state, action) {
 30:   switch (action.type) {
 31:     case 'INIT':
 32:       return { ...state, ...action.payload, loading: false };
 33:     case 'SET_TAB':
 34:       return { ...state, currentTab: action.tab, selectedCardId: null, editingCardId: null, editingProfileId: null };
 35:     case 'SELECT_CARD':
 36:       return { ...state, selectedCardId: action.id, editingCardId: null };
 37:     case 'EDIT_CARD':
 38:       return { ...state, editingCardId: action.id };
 39:     case 'STOP_EDITING':
 40:       return { ...state, editingCardId: null };
 41:     case 'DESELECT_CARD':
 42:       return { ...state, selectedCardId: null, editingCardId: null };
 43:     case 'SET_CARDS':
 44:       return { ...state, cards: action.cards };
 45:     case 'SET_PROFILES':
 46:       return { ...state, profiles: action.profiles };
 47:     case 'SET_TAGS':
 48:       return { ...state, tags: action.tags };
 49:     case 'SET_API_KEY':
 50:       return { ...state, apiKey: action.key };
 51:     case 'SET_FILTER_PROFILE':
 52:       return { ...state, filterProfile: action.value };
 53:     case 'SET_FILTER_TAG':
 54:       return { ...state, filterTag: action.value };
 55:     case 'SET_SEARCH':
 56:       return { ...state, searchQuery: action.value };
 57:     case 'SET_SCAN_PROFILE':
 58:       return { ...state, scanProfileId: action.id };
 59:     case 'EDIT_PROFILE':
 60:       return { ...state, editingProfileId: action.id };
 61:     case 'STOP_EDITING_PROFILE':
 62:       return { ...state, editingProfileId: null };
 63:     default:
 64:       return state;
 65:   }
 66: }
 67: 
 68: export function AppProvider({ children }) {
 69:   const [state, dispatch] = useReducer(reducer, initialState);
 70:   const saveCountRef = useRef(0);
 71: 
 72:   // ── Initialize ──
 73:   useEffect(() => {
 74:     async function init() {
 75:       // Try migrating from localStorage
 76:       const migrated = localStorage.getItem('grimoire-migrated-to-idb');
 77:       if (!migrated) {
 78:         await migrateFromLocalStorage();
 79:       }
 80: 
 81:       const [cards, profiles, tags, apiKey, scanProfileId] = await Promise.all([
 82:         getAllCards(),
 83:         getAllProfiles(),
 84:         getAllTags(),
 85:         getSetting('apiKey'),
 86:         getSetting('scanProfileId'),
 87:       ]);
 88: 
 89:       dispatch({
 90:         type: 'INIT',
 91:         payload: {
 92:           cards,
 93:           profiles,
 94:           tags,
 95:           apiKey: apiKey || '',
 96:           scanProfileId: scanProfileId || profiles[0]?.id || '',
 97:         },
 98:       });
 99:     }
100:     init();
101:   }, []);
102: 
103:   // ── Auto-backup every 10 saves ──
104:   useEffect(() => {
105:     if (saveCountRef.current > 0 && saveCountRef.current % 10 === 0) {
106:       createBackup().catch(console.error);
107:     }
108:   }, [state.cards, state.profiles, state.tags]);
109: 
110:   // ── Card actions ──
111:   const saveCard = useCallback(async (card) => {
112:     await putCard(card);
113:     const cards = await getAllCards();
114:     dispatch({ type: 'SET_CARDS', cards });
115:     saveCountRef.current++;
116:   }, []);
117: 
118:   const addCard = useCallback(async (card) => {
119:     const newCard = { ...card, id: card.id || genId(), createdAt: card.createdAt || Date.now() };
120:     await putCard(newCard);
121:     const cards = await getAllCards();
122:     dispatch({ type: 'SET_CARDS', cards });
123:     saveCountRef.current++;
124:     return newCard;
125:   }, []);
126: 
127:   const removeCard = useCallback(async (id) => {
128:     await dbDeleteCard(id);
129:     const cards = await getAllCards();
130:     dispatch({ type: 'SET_CARDS', cards });
131:     dispatch({ type: 'DESELECT_CARD' });
132:     saveCountRef.current++;
133:   }, []);
134: 
135:   // ── Profile actions ──
136:   const saveProfile = useCallback(async (profile) => {
137:     await putProfile(profile);
138:     const profiles = await getAllProfiles();
139:     dispatch({ type: 'SET_PROFILES', profiles });
140:     saveCountRef.current++;
141:   }, []);
142: 
143:   const addProfile = useCallback(async (profile) => {
144:     const newProfile = { ...profile, id: profile.id || genId() };
145:     await putProfile(newProfile);
146:     const profiles = await getAllProfiles();
147:     dispatch({ type: 'SET_PROFILES', profiles });
148:     return newProfile;
149:   }, []);
150: 
151:   const removeProfile = useCallback(async (id) => {
152:     await dbDeleteProfile(id);
153:     const profiles = await getAllProfiles();
154:     dispatch({ type: 'SET_PROFILES', profiles });
155:     dispatch({ type: 'STOP_EDITING_PROFILE' });
156:   }, []);
157: 
158:   // ── Tag actions ──
159:   const addTagAction = useCallback(async (name) => {
160:     await dbAddTag(name);
161:     const tags = await getAllTags();
162:     dispatch({ type: 'SET_TAGS', tags });
163:   }, []);
164: 
165:   const removeTagAction = useCallback(async (name) => {
166:     await dbRemoveTag(name);
167:     // Also remove from cards
168:     const cards = await getAllCards();
169:     for (const card of cards) {
170:       if (card.tags?.includes(name)) {
171:         card.tags = card.tags.filter((t) => t !== name);
172:         await putCard(card);
173:       }
174:     }
175:     const updatedCards = await getAllCards();
176:     dispatch({ type: 'SET_TAGS', tags: await getAllTags() });
177:     dispatch({ type: 'SET_CARDS', cards: updatedCards });
178:   }, []);
179: 
180:   // ── Settings actions ──
181:   const setApiKey = useCallback(async (key) => {
182:     await setSetting('apiKey', key);
183:     dispatch({ type: 'SET_API_KEY', key });
184:   }, []);
185: 
186:   const setScanProfileId = useCallback(async (id) => {
187:     await setSetting('scanProfileId', id);
188:     dispatch({ type: 'SET_SCAN_PROFILE', id });
189:   }, []);
190: 
191:   // ── QA state actions ──
192:   const getQAState = useCallback(async (checklistId) => {
193:     return dbGetQAState(checklistId);
194:   }, []);
195: 
196:   const saveQAState = useCallback(async (checklistId, stateData) => {
197:     await dbSaveQAState(checklistId, stateData);
198:   }, []);
199: 
200:   const resetQAState = useCallback(async (checklistId) => {
201:     await dbResetQAState(checklistId);
202:   }, []);
203: 
204:   // ── Card navigation with browser history ──
205:   const navigateToCard = useCallback((id, isRoot) => {
206:     dispatch({ type: 'SET_TAB', tab: 'library' });
207:     dispatch({ type: 'SELECT_CARD', id });
208:     history.pushState({ cardId: id, root: isRoot }, '');
209:   }, []);
210: 
211:   // Handle browser back/forward within card stack
212:   useEffect(() => {
213:     function onPopState(e) {
214:       const s = e.state;
215:       if (s?.cardId) {
216:         dispatch({ type: 'SET_TAB', tab: 'library' });
217:         dispatch({ type: 'SELECT_CARD', id: s.cardId });
218:       } else {
219:         dispatch({ type: 'DESELECT_CARD' });
220:       }
221:     }
222:     window.addEventListener('popstate', onPopState);
223:     return () => window.removeEventListener('popstate', onPopState);
224:   }, []);
225: 
226:   // ── Reload all data (after import) ──
227:   const reloadAll = useCallback(async () => {
228:     const [cards, profiles, tags] = await Promise.all([
229:       getAllCards(), getAllProfiles(), getAllTags(),
230:     ]);
231:     dispatch({ type: 'INIT', payload: { cards, profiles, tags, apiKey: state.apiKey, scanProfileId: state.scanProfileId } });
232:   }, [state.apiKey, state.scanProfileId]);
233: 
234:   const value = {
235:     state,
236:     dispatch,
237:     saveCard,
238:     addCard,
239:     removeCard,
240:     saveProfile,
241:     addProfile,
242:     removeProfile,
243:     addTag: addTagAction,
244:     removeTag: removeTagAction,
245:     setApiKey,
246:     setScanProfileId,
247:     reloadAll,
248:     navigateToCard,
249:     getQAState,
250:     saveQAState,
251:     resetQAState,
252:   };
253: 
254:   return <AppContext.Provider value={value}>{children}</AppContext.Provider>;
255: }
256: 
257: export function useApp() {
258:   const ctx = useContext(AppContext);
259:   if (!ctx) throw new Error('useApp must be inside AppProvider');
260:   return ctx;
261: }
</file>

