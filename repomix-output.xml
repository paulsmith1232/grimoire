 20:       const nameMatch = c.name?.toLowerCase().includes(q);
 21:       const textMatch = (c.sections || []).some((s) => {
 22:         const content = stripLinks(s.content || '');
 23:         const kvText = s.keyValues ? Object.values(s.keyValues).join(' ') : '';
 24:         return content.toLowerCase().includes(q) || kvText.toLowerCase().includes(q);
