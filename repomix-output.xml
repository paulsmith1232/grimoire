<file path="src/linking.js">
  1: // ── Link markup format: [[cardId|display text]] ──
  2: 
  3: const LINK_REGEX = /\[\[([^|\]]+)\|([^\]]+)\]\]/g;
  4: 
  5: /**
  6:  * Parse a text string and extract all links
  7:  * Returns array of { cardId, displayText, start, end }
  8:  */
  9: export function parseLinks(text) {
 10:   if (!text) return [];
 11:   const links = [];
 12:   let match;
 13:   const regex = new RegExp(LINK_REGEX.source, 'g');
 14:   while ((match = regex.exec(text)) !== null) {
 15:     links.push({
 16:       cardId: match[1],
 17:       displayText: match[2],
 18:       start: match.index,
 19:       end: match.index + match[0].length,
 20:       raw: match[0],
 21:     });
 22:   }
 23:   return links;
 24: }
 25: 
 26: /**
 27:  * Split text into segments of plain text and links for rendering
 28:  * Returns array of { type: 'text'|'link', content, cardId?, displayText? }
 29:  */
 30: export function segmentText(text) {
 31:   if (!text) return [];
 32:   const segments = [];
 33:   let lastIndex = 0;
 34:   const regex = new RegExp(LINK_REGEX.source, 'g');
 35:   let match;
 36: 
 37:   while ((match = regex.exec(text)) !== null) {
 38:     // Plain text before this link
 39:     if (match.index > lastIndex) {
 40:       segments.push({ type: 'text', content: text.slice(lastIndex, match.index) });
 41:     }
 42:     segments.push({
 43:       type: 'link',
 44:       content: match[2],
 45:       cardId: match[1],
 46:       displayText: match[2],
 47:     });
 48:     lastIndex = match.index + match[0].length;
 49:   }
 50: 
 51:   // Trailing text
 52:   if (lastIndex < text.length) {
 53:     segments.push({ type: 'text', content: text.slice(lastIndex) });
 54:   }
 55: 
 56:   return segments;
 57: }
 58: 
 59: /**
 60:  * Insert a link into text at the given range
 61:  */
 62: export function insertLink(text, start, end, cardId, displayText) {
 63:   const before = text.slice(0, start);
 64:   const after = text.slice(end);
 65:   return before + `[[${cardId}|${displayText}]]` + after;
 66: }
 67: 
 68: /**
 69:  * Remove a link from text, keeping the display text
 70:  */
 71: export function removeLink(text, cardId) {
 72:   return text.replace(new RegExp(`\\[\\[${escapeRegex(cardId)}\\|([^\\]]+)\\]\\]`, 'g'), '$1');
 73: }
 74: 
 75: /**
 76:  * Get plain text with all link markup stripped
 77:  */
 78: export function stripLinks(text) {
 79:   if (!text) return '';
 80:   return text.replace(LINK_REGEX, '$2');
 81: }
 82: 
 83: /**
 84:  * Compute reverse links: which cards link TO this card
 85:  * Returns array of { cardId, cardName, sectionName }
 86:  */
 87: export function computeReverseLinks(targetCardId, allCards) {
 88:   const refs = [];
 89:   for (const card of allCards) {
 90:     if (card.id === targetCardId) continue;
 91:     for (const sec of card.sections || []) {
 92:       const text = sec.content || '';
 93:       const kvText = sec.keyValues ? Object.values(sec.keyValues).join(' ') : '';
 94:       const combined = text + ' ' + kvText;
 95:       const links = parseLinks(combined);
 96:       if (links.some((l) => l.cardId === targetCardId)) {
 97:         refs.push({ cardId: card.id, cardName: card.name, sectionName: sec.name });
 98:       }
 99:     }
100:   }
101:   return refs;
102: }
103: 
104: /**
105:  * Get all card IDs referenced from a card's sections
106:  */
107: export function getOutgoingLinks(card) {
108:   const ids = new Set();
109:   for (const sec of card.sections || []) {
110:     const text = sec.content || '';
111:     const kvText = sec.keyValues ? Object.values(sec.keyValues).join(' ') : '';
112:     for (const link of parseLinks(text + ' ' + kvText)) {
113:       ids.add(link.cardId);
114:     }
115:   }
116:   return [...ids];
117: }
118: 
119: function escapeRegex(str) {
120:   return str.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
121: }
