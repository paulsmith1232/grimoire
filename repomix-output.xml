 20:   ctx.moveTo(x, y + arm);       ctx.lineTo(x, y);         ctx.lineTo(x + arm, y);
 21:   ctx.moveTo(x + w - arm, y);   ctx.lineTo(x + w, y);     ctx.lineTo(x + w, y + arm);
 22:   ctx.moveTo(x, y + h - arm);   ctx.lineTo(x, y + h);     ctx.lineTo(x + arm, y + h);
 23:   ctx.moveTo(x + w - arm, y + h); ctx.lineTo(x + w, y + h); ctx.lineTo(x + w, y + h - arm);
 24:   ctx.stroke();
 25: }
 26: 
 27: function drawXBtn(ctx, r) {
 28:   const { cx, cy } = getXBtnCenter(r);
 29:   ctx.fillStyle = 'rgba(20,14,8,0.88)';
 30:   ctx.beginPath();
 31:   ctx.arc(cx, cy, X_R, 0, Math.PI * 2);
 32:   ctx.fill();
 33:   ctx.strokeStyle = GOLD;
 34:   ctx.lineWidth = 1.5;
 35:   ctx.stroke();
 36:   const s = 4;
 37:   ctx.strokeStyle = '#fff';
 38:   ctx.lineWidth = 1.5;
 39:   ctx.lineCap = 'round';
 40:   ctx.beginPath();
 41:   ctx.moveTo(cx - s, cy - s); ctx.lineTo(cx + s, cy + s);
 42:   ctx.moveTo(cx + s, cy - s); ctx.lineTo(cx - s, cy + s);
 43:   ctx.stroke();
 44: }
