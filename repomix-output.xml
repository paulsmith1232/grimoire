211: // ── Auto-backup ──
212: export async function createBackup() {
213:   const cards = await getAllCards();
214:   const profiles = await getAllProfiles();
215:   const tags = await getAllTags();
216:   const backup = {
217:     id: 'backup-' + Date.now(),
218:     createdAt: Date.now(),
219:     data: { cards, profiles, tags },
220:   };
221:   await db.backups.put(backup);
222: 
223:   // Keep only last 5 backups
224:   const all = await db.backups.orderBy('createdAt').toArray();
225:   if (all.length > 5) {
226:     const toDelete = all.slice(0, all.length - 5);
227:     await db.backups.bulkDelete(toDelete.map((b) => b.id));
228:   }
229:   return backup;
230: }
