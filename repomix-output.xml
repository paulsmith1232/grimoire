 23:   async function handleFileSelect(e) {
 24:     const file = e.target.files?.[0];
 25:     if (!file) return;
 26:     e.target.value = '';
 27: 
 28:     // Load via blob URL into an <img> element. Chrome 81+ and Safari 14.2+ apply
 29:     // EXIF orientation automatically here (both naturalWidth/Height and drawImage),
 30:     // which is more consistent than createImageBitmap({imageOrientation}).
 31:     // Drawing to canvas re-encodes without EXIF, so CropOverlay receives a clean image.
 32:     const url = URL.createObjectURL(file);
 33:     await new Promise((resolve) => {
 34:       const img = new Image();
 35:       img.onload = () => {
 36:         const canvas = document.createElement('canvas');
 37:         canvas.width = img.naturalWidth;
 38:         canvas.height = img.naturalHeight;
 39:         canvas.getContext('2d').drawImage(img, 0, 0);
 40:         URL.revokeObjectURL(url);
 41:         const dataUrl = canvas.toDataURL('image/jpeg', 0.92);
 42:         setImgData({ dataUrl, base64: dataUrl.split(',')[1], mediaType: 'image/jpeg' });
 43:         setStatus('cropping');
